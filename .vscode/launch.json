{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "collect_data.py (Setup + Scraping)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/collect_data.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "collect_data.py (Browser sichtbar)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/collect_data.py",
      "args": ["--headed"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
